2 APPROACH .....  
class Solution {
    public boolean isPowerOfTwo(int n) {
      
        // 2 Approach :  using recursion

        // base case 
        if( n == 1) return true; // 2^0 = 1
        if(n <= 0 || n % 2 != 0) return false; // return false if this condition fail


        // rcursive call
        return isPowerOfTwo(n/2); // TC : O(logN) // SC : O(logN)
        
    }
}





