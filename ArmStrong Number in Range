import java.util.*;
class Main {
    public static void main(String[] args) {
        // printing armstrong number in range
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter the start point : ");
        int start = sc.nextInt();
        System.out.println("Enter the end point : ");
        int end = sc.nextInt();
        
        for(int num = start ; num <= end ; num++){
            int temp = num ;
            int digit_sum = 0;
            int power = getOrder(num);
            while(temp != 0){
                int d = temp % 10 ;
                digit_sum += (int)Math.pow(d,power) ;
                temp = temp / 10 ;
            }
            // if the num and digit both are equal then the current number will be armstrong number now we can print this
            if(digit_sum == num){
                System.out.print(num + " ");
            }
            
        }
    }
    public static int getOrder(int num){
        int power = 0 ;
        while(num != 0){
            power++;
            num = num / 10 ;
        }
        return power ;
    }
}


