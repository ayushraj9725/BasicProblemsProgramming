/// OPTIMAL SOLUTION ///  USING Ecludian Algorithm to find gcd using recursion 

class Solution {
  public:
    int gcd(int a, int b) {
        // code here
      
      if(a == 0){
          return b ;
      }
      if(b == 0){
          return a ;
      }
      if(a == b){
          return a ;
      }
      
      if(a > b){
         return gcd(a-b,b) ; // subtract b from a 
      }
      
      // otherwise a from b
        
      return gcd(a,b-a);
      
    }
};

