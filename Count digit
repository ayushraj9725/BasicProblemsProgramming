Problem : Count digit in number how many divide the number evenly

Problem Statement : 
Given a positive integer n, count the number of digits in n that divide n evenly (i.e., without leaving a remainder). Return the total number of such digits.

A digit d of n divides n evenly if the remainder when n is divided by d is 0 (n % d == 0).
Digits of n should be checked individually. If a digit is 0, it should be ignored because division by 0 is undefined.

Examples :

Input: n = 12
Output: 2
Explanation: 1, 2 when both divide 12 leaves remainder 0.

Input: n = 2446
Output: 1
Explanation: Here among 2, 4, 6 only 2 divides 2446 evenly while 4 and 6 do not.

Input: n = 23
Output: 0
Explanation: 2 and 3, none of them divide 23 evenly.

Problem Solution : C++ 

class Solution {
  public:
    // Function to count the number of digits in n that evenly divide n
    int evenlyDivides(int n) {
        // code here
        
        // Approach 1 using modulo operator and check divisibility 
        
        int count = 0 ;
        int num = n ;
        
        while(num != 0){
            int curr_digit = num % 10 ;  // current digit
            num /= 10 ; // trim the digit from num 
            
            // if it is ture then only we will increment the counter otherwise not
            if(curr_digit != 0 && isEvenlyDivide(n,curr_digit)){
                count++ ;
            }
        }
        return count ;
    }
    
    bool isEvenlyDivide(int num,int digit){
        
        if(num % digit == 0){
            return true ;
        }
        return false ;
        
    }
    
    // time complexity : O(log10N) and Space comp : O(1)
};

/////////////  JAVA solution /////////////////

class Solution {
    
    static int evenlyDivides(int n) {
        
        int count = 0;
        int num = n;
        
        while(num != 0){
            int digit = num % 10;   // get last digit
            num /= 10;              // remove last digit
            
            if(digit != 0 && n % digit == 0){
                count++;
            }
        }
        
        return count;
    }
}
